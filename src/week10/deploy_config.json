{
  "project_name": "chatbot-tutor-memory",
  "version": "1.0.0",
  "author": "Riyash Subba",
  "environment": "production",
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "workers": 2,
    "timeout_seconds": 60
  },
  "database": {
    "chroma_dir": "./chroma_db",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2"
  },
  "model": {
    "provider": "huggingface",
    "llm_name": "distilgpt2",
    "max_new_tokens": 128,
    "temperature": 0.7
  },
  "monitoring": {
    "enabled": true,
    "log_level": "INFO",
    "metrics_port": 9090
  }
}
